{
  "name": "GitHub Devin Review Toggle",
  "description": "Toggle the current tab between a GitHub pull request and the matching Devin review page.",
  "version": "0.1.0",
  "manifest_version": 3,
  "permissions": ["tabs"],
  "host_permissions": ["https://github.com/*", "https://app.devin.ai/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Toggle GitHub / Devin review",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "commands": {
    "toggle-review-target": {
      "description": "Toggle between the GitHub pull request and Devin review for the current tab"
    }
  }
}
